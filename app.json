{
  "expo": {
    "name": "SENTINELA",
    "slug": "sentinela",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "sentinela",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,

    "icon": "./src/assets/Logo-SentinelaSemFundo.png",

    "splash": {
      "image": "./src/assets/Logo-SentinelaSemFundo.png",
      "resizeMode": "contain",
      "backgroundColor": "#0F172A"
    },

    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.sentinela.app"
    },

    "android": {
      "package": "br.com.sentinelaapp",
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,

      "adaptiveIcon": {
        "foregroundImage": "./src/assets/Logo-SentinelaSemFundo.png",
        "backgroundColor": "#0F172A"
      }
    },

    "web": {
      "favicon": "./src/assets/Logo-SentinelaSemFundo.png"
    },

    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./src/assets/Logo-SentinelaSemFundo.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#0F172A"
        }
      ]
    ],

    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}